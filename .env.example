# AutoClip Pro environment configuration
# Copy to .env and fill in values

# Google Gemini API key (recommended for highlight detection)
AUTOCLIP_GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model
AUTOCLIP_GEMINI_MODEL=gemini-2.5-flash

# OpenAI API key (alternative to Gemini)
AUTOCLIP_OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model for highlight detection
AUTOCLIP_OPENAI_MODEL=gpt-4o-mini

# Whisper model size: tiny, base, small, medium, large
AUTOCLIP_WHISPER_MODEL=base

# Clip duration constraints (seconds)
AUTOCLIP_MIN_CLIP_DURATION=15.0
AUTOCLIP_MAX_CLIP_DURATION=90.0
AUTOCLIP_MAX_CLIPS=10

# API settings
AUTOCLIP_API_HOST=0.0.0.0
AUTOCLIP_API_PORT=8000
